# Ship the user-facing docs and license in the source distribution. README is already pulled in
# via pyproject's `readme =`, and setuptools includes LICENSE by default, but list them here too
# so the sdist is self-contained and explicit.
include README.md
include INSTALL.md
include CHANGELOG.md
include LICENSE

# The docs/ guides the README/INSTALL link to (modern-config + control-channel references, and
# the user-guide chapter sources under docs/guide/src), plus the generated plain-text user guide
# (#64) as the offline copy. The HTML build tooling (tools/) and the generated site/ stay out.
recursive-include docs *.md
include docs/guide/psysmon-guide.txt

# Bundled runtime asset: the status-page logo the daemon deploys next to the status file.
recursive-include psysmon/assets *.png
